{% comment %}
  Contact Info Section - Información de contacto
  Dirección, teléfono, email, horarios, redes sociales
{% endcomment %}

{%- liquid
  assign heading = section.settings.heading
  assign bg_color = section.settings.background_color
-%}

<section 
  class="contact-info contact-info--{{ section.id }}"
  style="--contact-info-bg: {{ bg_color }};"
>
  <div class="contact-info__container">
    
    {%- if heading != blank -%}
      <h2 class="contact-info__heading fade-in-up">
        {{ heading }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="contact-info__grid">
        {%- for block in section.blocks -%}
          <div class="contact-info__item fade-in-up" {{ block.shopify_attributes }}>
            
            {%- if block.settings.icon != blank -%}
              <div class="contact-info__icon">
                {{ block.settings.icon }}
              </div>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="contact-info__title">
                {{ block.settings.title }}
              </h3>
            {%- endif -%}

            {%- if block.settings.content != blank -%}
              <div class="contact-info__content">
                {{ block.settings.content }}
              </div>
            {%- endif -%}

            {%- if block.settings.link_text != blank and block.settings.link_url != blank -%}
              <a href="{{ block.settings.link_url }}" class="contact-info__link">
                {{ block.settings.link_text }}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            {%- endif -%}

          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Mapa opcional - ABAJO DEL TODO {%- endcomment -%}
    {%- if section.settings.show_map and section.settings.map_url != blank -%}
      <div class="contact-info__map fade-in-up">
        <iframe
          src="{{ section.settings.map_url }}"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  .contact-info--{{ section.id }} {
    background-color: var(--contact-info-bg);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .contact-info--{{ section.id }} .contact-info__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }

  /* Heading */
  .contact-info--{{ section.id }} .contact-info__heading {
    font-family: 'Playfair Display', 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    text-align: center;
    margin-bottom: var(--spacing-xl);
    color: var(--color-charcoal);
  }

  /* Grid - 4 COLUMNAS EN DESKTOP */
  .contact-info--{{ section.id }} .contact-info__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }

  /* Item - MENOS PADDING */
  .contact-info--{{ section.id }} .contact-info__item {
    background-color: var(--color-white);
    padding: var(--spacing-xs); 
    padding-top: var(--spacing-md);
    border-radius: 8px;
    border: 1px solid var(--color-light-gray);
    text-align: center;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
  }

  .contact-info--{{ section.id }} .contact-info__item:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.1);
    border-color: var(--color-gold);
  }

  /* Icon */
  .contact-info--{{ section.id }} .contact-info__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 50px; /* REDUCIDO de 60px */
    height: 50px;
    background: linear-gradient(135deg, var(--color-gold), #d4af7a);
    border-radius: 50%;
    margin-bottom: var(--spacing-sm); /* REDUCIDO */
    color: var(--color-white);
    font-size: 1.3rem;
  }

  .contact-info--{{ section.id }} .contact-info__icon svg {
    width: 24px; /* REDUCIDO de 28px */
    height: 24px;
    stroke-width: 2;
  }

  /* Title */
  .contact-info--{{ section.id }} .contact-info__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem; /* REDUCIDO de 1.5rem */
    font-weight: 500;
    margin-bottom: var(--spacing-xs); /* REDUCIDO */
    color: var(--color-charcoal);
  }

  /* Content */
  .contact-info--{{ section.id }} .contact-info__content {
    font-size: 0.95rem; /* REDUCIDO de 1rem */
    line-height: 1.6;
    color: var(--color-gray);
    margin-bottom: var(--spacing-sm); /* REDUCIDO */
  }

  .contact-info--{{ section.id }} .contact-info__content p {
    margin-bottom: var(--spacing-xs);
  }

  .contact-info--{{ section.id }} .contact-info__content a {
    color: var(--color-charcoal);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .contact-info--{{ section.id }} .contact-info__content a:hover {
    color: var(--color-gold);
  }

  /* Link */
  .contact-info--{{ section.id }} .contact-info__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-gold);
    font-weight: 500;
    font-size: 0.85rem; /* REDUCIDO */
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .contact-info--{{ section.id }} .contact-info__link svg {
    transition: transform 0.3s ease;
  }

  .contact-info--{{ section.id }} .contact-info__link:hover {
    color: var(--color-charcoal);
  }

  .contact-info--{{ section.id }} .contact-info__link:hover svg {
    transform: translateX(5px);
  }

  /* Map - ASPECT RATIO CORRECTO */
  .contact-info--{{ section.id }} .contact-info__map {
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    border: 1px solid var(--color-light-gray);
    margin-top: var(--spacing-lg);
    width: 100%;
    height: 500px; /* Altura fija para desktop */
    position: relative;
  }

  .contact-info--{{ section.id }} .contact-info__map iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* Responsive - MÓVIL 1 COLUMNA */
  @media (max-width: 1024px) {
    .contact-info--{{ section.id }} .contact-info__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .contact-info--{{ section.id }} .contact-info__map {
      height: 400px; /* Menos alto en tablet */
    }
  }

  @media (max-width: 767px) {
    .contact-info--{{ section.id }} {
      padding: {{ section.settings.padding_top | divided_by: 1.5 }}px 0 {{ section.settings.padding_bottom | divided_by: 1.5 }}px;
    }

    .contact-info--{{ section.id }} .contact-info__grid {
      grid-template-columns: 1fr;
    }
    
    .contact-info--{{ section.id }} .contact-info__map {
      height: 350px; /* Perfecto en móvil */
    }
  }
</style>

{% schema %}
