{% comment %}
  About Content Section - Imagen + Texto configurable
  Layout reversible, completamente editable
  VERSION PROFESIONAL - image_tag moderno con responsive images
{% endcomment %}

{%- liquid
  assign layout = section.settings.layout
  assign heading = section.settings.heading
  assign content = section.settings.content
  assign section_image = section.settings.image
  assign bg_color = section.settings.background_color
-%}

<section 
  class="about-content about-content--{{ section.id }}"
  style="--about-content-bg: {{ bg_color }};"
>
  <div class="about-content__container">
    <div class="about-content__grid about-content__grid--{{ layout }}">
      
      {%- comment -%} Imagen - image_tag moderno {%- endcomment -%}
      <div class="about-content__image-wrapper fade-in-{{ layout }}">
        {%- if section_image != blank -%}
          {{ section_image | image_url: width: 1000 | image_tag:
            loading: 'lazy',
            widths: '400, 600, 800, 1000',
            sizes: '(min-width: 768px) 50vw, 100vw',
            class: 'about-content__image',
            alt: section_image.alt
          }}
        {%- else -%}
          <div class="about-content__placeholder">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Contenido {%- endcomment -%}
      <div class="about-content__text-wrapper fade-in-up">
        {%- if heading != blank -%}
          <h2 class="about-content__heading">
            {{ heading }}
          </h2>
        {%- endif -%}

        {%- if content != blank -%}
          <div class="about-content__text">
            {{ content }}
          </div>
        {%- endif -%}

        {%- if section.settings.button_text != blank and section.settings.button_link != blank -%}
          <div class="about-content__button">
            <a href="{{ section.settings.button_link }}" class="btn btn-secondary">
              {{ section.settings.button_text }}
            </a>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

<style>
  .about-content--{{ section.id }} {
    background-color: var(--about-content-bg);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .about-content--{{ section.id }} .about-content__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }

  .about-content--{{ section.id }} .about-content__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
    align-items: center;
  }

  @media (min-width: 768px) {
    .about-content--{{ section.id }} .about-content__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--spacing-xl) 4rem;
    }

    /* Layout: imagen a la derecha */
    .about-content--{{ section.id }} .about-content__grid--right .about-content__image-wrapper {
      order: 2;
    }

    .about-content--{{ section.id }} .about-content__grid--right .about-content__text-wrapper {
      order: 1;
    }
  }

  /* Imagen */
  .about-content--{{ section.id }} .about-content__image-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.image_border_radius }}px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
  }

  .about-content--{{ section.id }} .about-content__image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s ease;
  }

  .about-content--{{ section.id }} .about-content__image-wrapper:hover .about-content__image {
    transform: scale(1.05);
  }

  .about-content--{{ section.id }} .about-content__placeholder {
    aspect-ratio: 4/3;
    background-color: var(--color-light-gray);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-content--{{ section.id }} .placeholder-svg {
    width: 40%;
    height: 40%;
    opacity: 0.3;
  }

  /* Texto */
  .about-content--{{ section.id }} .about-content__heading {
    font-family: 'Playfair Display', 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    margin-bottom: var(--spacing-md);
    color: var(--color-charcoal);
    line-height: 1.3;
  }

  .about-content--{{ section.id }} .about-content__text {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-gray);
    margin-bottom: var(--spacing-lg);
  }

  .about-content--{{ section.id }} .about-content__text p {
    margin-bottom: var(--spacing-md);
  }

  .about-content--{{ section.id }} .about-content__text p:last-child {
    margin-bottom: 0;
  }

  .about-content--{{ section.id }} .about-content__button {
    margin-top: var(--spacing-lg);
  }

  /* Responsive */
  @media (max-width: 767px) {
    .about-content--{{ section.id }} {
      padding: {{ section.settings.padding_top | divided_by: 1.5 }}px 0 {{ section.settings.padding_bottom | divided_by: 1.5 }}px;
    }
  }
</style>

{% schema %}
{
  "name": "About Content",
  "tag": "section",
  "class": "section-about-content",
  "settings": [
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Nuestra Historia"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Contenido",
      "default": "<p>Escribe aquí la historia de tu galería, artista o colección.</p>"
    },
    {
      "type": "header",
      "content": "Imagen"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Posición de la imagen",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Radio de borde de imagen",
      "default": 4
    },
    {
      "type": "header",
      "content": "Botón (opcional)"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón"
    },
    {
      "type": "header",
      "content": "Colores y espaciado"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Espaciado superior",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Espaciado inferior",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "About Content",
      "settings": {
        "heading": "Nuestra Historia",
        "content": "<p>Escribe aquí la historia de tu galería, artista o colección.</p>"
      }
    }
  ]
}
{% endschema %}