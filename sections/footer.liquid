{% comment %}
  Footer Section - Shopify 2.0 Standards Compliant
  Fully configurable with blocks
{% endcomment %}

<footer class="site-footer section-{{ section.id }}" role="contentinfo">
  <div class="footer-content">
    
    {%- comment -%} Logo and description {%- endcomment -%}
    {% if section.settings.show_logo %}
      <div class="footer-logo-section">
        {% if section.settings.logo != blank %}
          <img 
            src="{{ section.settings.logo | image_url: width: 200 }}" 
            alt="{{ shop.name }}"
            width="200"
            height="auto"
            loading="lazy"
            class="footer-logo-image"
          >
        {% else %}
          <p class="footer-logo">{{ section.settings.logo_text | default: shop.name }}</p>
        {% endif %}
        
        {% if section.settings.description != blank %}
          <div class="footer-description">
            {{ section.settings.description }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {%- comment -%} Footer blocks (menus, newsletter, etc.) {%- endcomment -%}
    {% if section.blocks.size > 0 %}
      <div class="footer-blocks">
        {% for block in section.blocks %}
          <div class="footer-block footer-block--{{ block.type }}" {{ block.shopify_attributes }}>
            
            {%- case block.type -%}
              
              {%- when 'menu' -%}
                {% if block.settings.menu != blank %}
                  <h3 class="footer-block__heading">{{ block.settings.heading }}</h3>
                  <ul class="footer-menu">
                    {% for link in block.settings.menu.links %}
                      <li class="footer-menu__item">
                        <a href="{{ link.url }}" class="footer-menu__link">
                          {{ link.title }}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}

              {%- when 'text' -%}
                <h3 class="footer-block__heading">{{ block.settings.heading }}</h3>
                <div class="footer-text">
                  {{ block.settings.text }}
                </div>

              {%- when 'newsletter' -%}
                <h3 class="footer-block__heading">{{ block.settings.heading }}</h3>
                <div class="footer-newsletter">
                  {% if block.settings.subheading != blank %}
                    <p class="footer-newsletter__subheading">{{ block.settings.subheading }}</p>
                  {% endif %}
                  {% form 'customer', class: 'newsletter-form' %}
                    {% if form.posted_successfully? %}
                      <p class="newsletter-form__success">{{ 'newsletter.success' | t }}</p>
                    {% endif %}
                    
                    <div class="newsletter-form__fields">
                      <input
                        type="email"
                        name="contact[email]"
                        class="newsletter-form__input"
                        placeholder="{{ 'newsletter.email_placeholder' | t }}"
                        aria-label="{{ 'newsletter.email_placeholder' | t }}"
                        required
                      >
                      <button type="submit" class="newsletter-form__submit btn btn-primary">
                        {{ 'newsletter.submit' | t }}
                      </button>
                    </div>
                    
                    {% if form.errors %}
                      <p class="newsletter-form__error">{{ form.errors | default_errors }}</p>
                    {% endif %}
                  {% endform %}
                </div>

              {%- when 'social' -%}
                <h3 class="footer-block__heading">{{ block.settings.heading }}</h3>
                <ul class="footer-social">
                  {% if settings.social_facebook_link != blank %}
                    <li class="footer-social__item">
                      <a href="{{ settings.social_facebook_link }}" 
                         class="footer-social__link" 
                         aria-label="Facebook"
                         target="_blank"
                         rel="noopener">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                        </svg>
                      </a>
                    </li>
                  {% endif %}
                  
                  {% if settings.social_instagram_link != blank %}
                    <li class="footer-social__item">
                      <a href="{{ settings.social_instagram_link }}" 
                         class="footer-social__link" 
                         aria-label="Instagram"
                         target="_blank"
                         rel="noopener">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                        </svg>
                      </a>
                    </li>
                  {% endif %}
                  
                  {% if settings.social_twitter_link != blank %}
                    <li class="footer-social__item">
                      <a href="{{ settings.social_twitter_link }}" 
                         class="footer-social__link" 
                         aria-label="Twitter"
                         target="_blank"
                         rel="noopener">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                        </svg>
                      </a>
                    </li>
                  {% endif %}
                  
                  {% if settings.social_pinterest_link != blank %}
                    <li class="footer-social__item">
                      <a href="{{ settings.social_pinterest_link }}" 
                         class="footer-social__link" 
                         aria-label="Pinterest"
                         target="_blank"
                         rel="noopener">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/>
                        </svg>
                      </a>
                    </li>
                  {% endif %}
                </ul>

            {%- endcase -%}
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {%- comment -%} Payment icons {%- endcomment -%}
    {% if section.settings.show_payment_icons %}
      <div class="footer-payment">
        {% for type in shop.enabled_payment_types %}
          {{ type | payment_type_svg_tag: class: 'footer-payment__icon' }}
        {% endfor %}
      </div>
    {% endif %}

    {%- comment -%} Copyright {%- endcomment -%}
    <div class="footer-copyright">
      <p>
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. 
        {{ 'footer.all_rights_reserved' | t }}
      </p>
      {% if section.settings.show_powered_by %}
        <p class="footer-powered">
          {{ powered_by_link }}
        </p>
      {% endif %}
    </div>

  </div>
</footer>

<style>
  .section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
  }

  .section-{{ section.id }} .footer-logo {
    color: {{ section.settings.logo_color }};
  }

  .section-{{ section.id }} .footer-menu__link:hover,
  .section-{{ section.id }} .footer-social__link:hover {
    color: {{ section.settings.link_hover_color }};
  }
</style>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "checkbox",
      "id": "show_logo",
      "label": "Show logo",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text (if no image)",
      "default": "Art Gallery"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#2C2C2C"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "logo_color",
      "label": "Logo color",
      "default": "#C9A961"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#C9A961"
    },
    {
      "type": "header",
      "content": "Additional options"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_powered_by",
      "label": "Show 'Powered by Shopify'",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "About us"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Share information about your brand with your customers.</p>"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Newsletter"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Subscribe to get special offers and updates"
        }
      ]
    },
    {
      "type": "social",
      "name": "Social media",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Follow us"
        },
        {
          "type": "paragraph",
          "content": "Add your social media links in Theme settings > Social media"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "menu"
      },
      {
        "type": "newsletter"
      },
      {
        "type": "social"
      }
    ]
  }
}
{% endschema %}
