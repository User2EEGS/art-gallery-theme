{% comment %}
  Rich Text Section - Shopify 2.0
  Flexible text content section
{% endcomment %}

<div 
  class="rich-text-section section-{{ section.id }}"
  style="
    --richtext-bg: {{ section.settings.background_color }};
    --richtext-text: {{ section.settings.text_color }};
  "
>
  <div class="rich-text-section__container">
    <div class="rich-text-content rich-text-content--{{ section.settings.text_alignment }}">
      
      {% if section.settings.subheading != blank %}
        <p class="rich-text__subheading">
          {{ section.settings.subheading }}
        </p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="rich-text__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="rich-text__text">
          {{ section.settings.text }}
        </div>
      {% endif %}

      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <div class="rich-text__button">
          <a 
            href="{{ section.settings.button_link }}" 
            class="btn {% if section.settings.button_style == 'primary' %}btn-primary{% else %}btn-secondary{% endif %}"
          >
            {{ section.settings.button_label }}
          </a>
        </div>
      {% endif %}

    </div>
  </div>
</div>

<style>
  .section-{{ section.id }} {
    background-color: var(--richtext-bg);
    color: var(--richtext-text);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} .rich-text-section__container {
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }

  .section-{{ section.id }} .rich-text-content--left {
    text-align: left;
  }

  .section-{{ section.id }} .rich-text-content--center {
    text-align: center;
    margin: 0 auto;
  }

  .section-{{ section.id }} .rich-text-content--right {
    text-align: right;
  }

  .section-{{ section.id }} .rich-text__subheading {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    margin-bottom: var(--spacing-sm);
    font-weight: 500;
  }

  .section-{{ section.id }} .rich-text__heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: var(--spacing-lg);
    color: var(--richtext-text);
  }

  .section-{{ section.id }} .rich-text__text {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--richtext-text);
  }

  .section-{{ section.id }} .rich-text__text p {
    margin-bottom: var(--spacing-md);
  }

  .section-{{ section.id }} .rich-text__text h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-md);
  }

  .section-{{ section.id }} .rich-text__text ul,
  .section-{{ section.id }} .rich-text__text ol {
    margin-bottom: var(--spacing-md);
    padding-left: var(--spacing-lg);
  }

  .section-{{ section.id }} .rich-text__text li {
    margin-bottom: var(--spacing-sm);
  }

  .section-{{ section.id }} .rich-text__text a {
    color: var(--color-gold);
    text-decoration: underline;
    transition: opacity 0.3s ease;
  }

  .section-{{ section.id }} .rich-text__text a:hover {
    opacity: 0.7;
  }

  .section-{{ section.id }} .rich-text__button {
    margin-top: var(--spacing-lg);
  }

  .section-{{ section.id }} .rich-text-content--center .rich-text__button {
    display: flex;
    justify-content: center;
  }

  .section-{{ section.id }} .rich-text-content--right .rich-text__button {
    display: flex;
    justify-content: flex-end;
  }
</style>

{% schema %}
{
  "name": "Rich Text",
  "tag": "section",
  "class": "section-rich-text",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Share Your Story"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Use this section to share information about your brand, your story, or your process. Connect with your customers on a personal level.</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        {
          "value": "primary",
          "label": "Primary"
        },
        {
          "value": "secondary",
          "label": "Secondary"
        }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#2C2C2C"
    },
    {
      "type": "header",
      "content": "Section settings"
    },
    {
      "type": "range",
      "id": "content_width",
      "min": 600,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Content width",
      "default": 800
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Rich Text",
      "settings": {
        "heading": "About Our Studio",
        "text": "<p>We are passionate about creating art that transforms spaces and inspires emotion. Each piece is crafted with dedication and attention to detail.</p>"
      }
    }
  ]
}
{% endschema %}