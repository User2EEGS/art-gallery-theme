{% comment %}
  About Hero Section - Profesional y configurable
  Para cualquier página - Fondos personalizables
  VERSION PROFESIONAL - image_tag moderno con responsive images
{% endcomment %}

{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign text_alignment = section.settings.text_alignment
  assign show_pattern = section.settings.show_pattern
  assign overlay_opacity = section.settings.overlay_opacity
-%}

<section 
  class="about-hero about-hero--{{ section.id }}"
  style="
    --about-label-color: {{ section.settings.label_color }};
    --about-heading-color: {{ section.settings.heading_color }};
    --about-subheading-color: {{ section.settings.subheading_color }};
  "
>
  {%- comment -%} Imagen de fondo O degradado {%- endcomment -%}
  <div class="about-hero__background">
    {% if section.settings.background_image != blank %}
      {{- section.settings.background_image | image_url: width: 2000 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        sizes: '100vw',
        widths: '800, 1200, 1600, 2000',
        class: 'about-hero__image',
        alt: heading | escape
      -}}
      <div class="about-hero__overlay" style="opacity: {{ overlay_opacity | divided_by: 100.0 }};"></div>
    {% else %}
      <div 
        class="about-hero__gradient"
        style="background: linear-gradient(135deg, {{ section.settings.gradient_color_1 }} 0%, {{ section.settings.gradient_color_2 }} 100%);"
      ></div>
    {% endif %}
  </div>

  {%- if show_pattern -%}
    <div class="about-hero__pattern" aria-hidden="true"></div>
  {%- endif -%}

  <div class="about-hero__container">
    <div class="about-hero__content" style="text-align: {{ text_alignment }};">
      
      {%- if section.settings.small_label != blank -%}
        <p class="about-hero__label fade-in-up">
          {{ section.settings.small_label }}
        </p>
      {%- endif -%}

      {%- if heading != blank -%}
        <h1 class="about-hero__heading fade-in-up">
          {{ heading }}
        </h1>
      {%- endif -%}

      {%- if subheading != blank -%}
        <div class="about-hero__subheading fade-in-up">
          {{ subheading }}
        </div>
      {%- endif -%}

      {%- if section.settings.button_text != blank and section.settings.button_link != blank -%}
        <div class="about-hero__button fade-in-up">
          <a href="{{ section.settings.button_link }}" class="btn btn-primary">
            {{ section.settings.button_text }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .about-hero--{{ section.id }} {
    position: relative;
    padding: calc(140px + 4rem) var(--spacing-md) var(--spacing-xl);
    overflow: hidden;
    min-height: {{ section.settings.min_height }}vh;
    display: flex;
    align-items: center;
  }

  @media (max-width: 768px) {
    .about-hero--{{ section.id }} {
      padding: calc(100px + 2rem) var(--spacing-sm) var(--spacing-lg);
      min-height: calc({{ section.settings.min_height }}vh - 10vh);
    }
  }

  /* Background */
  .about-hero--{{ section.id }} .about-hero__background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .about-hero--{{ section.id }} .about-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .about-hero--{{ section.id }} .about-hero__gradient {
    width: 100%;
    height: 100%;
  }

  .about-hero--{{ section.id }} .about-hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 1);
    z-index: 1;
  }

  /* Patrón decorativo */
  .about-hero--{{ section.id }} .about-hero__pattern {
    position: absolute;
    top: -50%;
    right: -20%;
    width: 80%;
    height: 150%;
    background: radial-gradient(
      circle at center,
      rgba(201, 169, 97, 0.04) 0%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 1;
    animation: float 20s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% {
      transform: translate(0, 0) rotate(0deg);
    }
    33% {
      transform: translate(30px, -30px) rotate(2deg);
    }
    66% {
      transform: translate(-20px, 20px) rotate(-2deg);
    }
  }

  .about-hero--{{ section.id }} .about-hero__container {
    width: 100%;
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  /* Etiqueta pequeña - COLOR PERSONALIZABLE */
  .about-hero--{{ section.id }} .about-hero__label {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--about-label-color);
    margin-bottom: var(--spacing-sm);
    font-family: 'Lato', sans-serif;
  }

  /* Título principal - COLOR PERSONALIZABLE */
  .about-hero--{{ section.id }} .about-hero__heading {
    font-family: 'Playfair Display', 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: var(--spacing-md);
    letter-spacing: -0.02em;
    color: var(--about-heading-color);
  }

  /* Subtítulo - COLOR PERSONALIZABLE */
  .about-hero--{{ section.id }} .about-hero__subheading {
    font-size: clamp(1rem, 2vw, 1.3rem);
    line-height: 1.8;
    margin-bottom: var(--spacing-lg);
    color: var(--about-subheading-color);
  }

  .about-hero--{{ section.id }} .about-hero__subheading p {
    margin-bottom: var(--spacing-md);
  }

  .about-hero--{{ section.id }} .about-hero__button {
    margin-top: var(--spacing-lg);
  }

  /* Animaciones */
  .fade-in-up {
    opacity: 1;
    transform: translateY(0);
  }

  /* Reducir movimiento para accesibilidad */
  @media (prefers-reduced-motion: reduce) {
    .about-hero--{{ section.id }} .about-hero__pattern {
      animation: none;
    }
  }
</style>

{% schema %}
{
  "name": "About Hero",
  "tag": "section",
  "class": "section-about-hero",
  "settings": [
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "small_label",
      "label": "Etiqueta pequeña",
      "default": "Bienvenido"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título principal",
      "default": "Quiénes Somos"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subtítulo / Descripción",
      "default": "<p>Descubre nuestra historia y pasión por el arte.</p>"
    },
    {
      "type": "header",
      "content": "Botón (opcional)"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón"
    },
    {
      "type": "header",
      "content": "Fondo"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Imagen de fondo",
      "info": "Si no seleccionas imagen, se usará el degradado de colores"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Opacidad de superposición oscura",
      "default": 30,
      "info": "Solo se aplica con imagen de fondo"
    },
    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Color degradado 1",
      "default": "#FAFAF8",
      "info": "Se usa si NO hay imagen de fondo"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Color degradado 2",
      "default": "#FFFFFF",
      "info": "Se usa si NO hay imagen de fondo"
    },
    {
      "type": "header",
      "content": "Colores del texto"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Color etiqueta pequeña",
      "default": "#C9A961",
      "info": "Color del texto 'Bienvenido'"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color título principal",
      "default": "#2C2C2C",
      "info": "Color del título grande"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Color subtítulo/descripción",
      "default": "#2C2C2C",
      "info": "Color del texto descriptivo"
    },
    {
      "type": "header",
      "content": "Diseño"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alineación del texto",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_width",
      "min": 600,
      "max": 1400,
      "step": 100,
      "unit": "px",
      "label": "Ancho máximo del contenido",
      "default": 900
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Altura mínima",
      "default": 60
    },
    {
      "type": "checkbox",
      "id": "show_pattern",
      "label": "Mostrar patrón decorativo",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "About Hero",
      "settings": {
        "small_label": "Bienvenido",
        "heading": "Quiénes Somos",
        "subheading": "<p>Descubre nuestra historia y pasión por el arte.</p>"
      }
    }
  ]
}
{% endschema %}