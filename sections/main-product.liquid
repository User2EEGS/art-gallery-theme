{% comment %}
  Main Product Section - Shopify 2.0 with Custom Elements
  Standards compliant for Theme Store submission
{% endcomment %}

{%- liquid
  assign product = product
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = current_variant.featured_image | default: product.featured_image
  assign product_form_id = 'product-form-' | append: section.id
-%}

<link rel="stylesheet" href="{{ 'product-info.js' | asset_url }}" as="script">
<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>

<product-info class="product-page section-{{ section.id }}">
  <div class="product-page__container">
    
    {%- comment -%} Product Images Gallery {%- endcomment -%}
    <product-gallery class="product-gallery">
      {% if product.images.size > 0 %}
        <div class="product-gallery__main">
          <div class="product-gallery__main-image" data-main-image>
            {{- featured_image | image_url: width: 1200 | image_tag:
              loading: 'eager',
              sizes: '(min-width: 1200px) 50vw, (min-width: 768px) 60vw, 100vw',
              widths: '400, 600, 800, 1000, 1200',
              class: 'product-image',
              alt: featured_image.alt | default: product.title
            -}}
          </div>

          {% if product.images.size > 1 %}
            <div class="product-gallery__thumbnails">
              {% for image in product.images limit: 6 %}
                <button 
                  type="button"
                  class="product-thumbnail {% if image == featured_image %}active{% endif %}"
                  data-thumbnail
                  data-image-url="{{ image | image_url: width: 1200 }}"
                  data-image-srcset="{{ image | image_url: width: 400 }} 400w, {{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 800 }} 800w, {{ image | image_url: width: 1000 }} 1000w, {{ image | image_url: width: 1200 }} 1200w"
                  data-image-alt="{{ image.alt | default: product.title | escape }}"
                  aria-label="{{ 'products.product.view_image' | t: index: forloop.index }}"
                >
                  {{- image | image_url: width: 200 | image_tag:
                    loading: 'lazy',
                    sizes: '100px',
                    widths: '100, 200',
                    alt: image.alt | default: product.title
                  -}}
                </button>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% else %}
        <div class="product-gallery__placeholder">
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {% endif %}
    </product-gallery>

    {%- comment -%} Product Information {%- endcomment -%}
    <div class="product-info">
      
      {%- comment -%} Vendor/Artist {%- endcomment -%}
      {% if section.settings.show_vendor and product.vendor != blank %}
        <p class="product-vendor">{{ product.vendor }}</p>
      {% endif %}

      {%- comment -%} Product Title {%- endcomment -%}
      <h1 class="product-title">{{ product.title }}</h1>

      {%- comment -%} Price {%- endcomment -%}
      <div class="product-price-wrapper">
        <div class="product-price" id="price-{{ section.id }}">
          <span class="product-price__regular">
            {{ current_variant.price | money }}
          </span>
          
          {% if current_variant.compare_at_price > current_variant.price %}
            <span class="product-price__compare">
              {{ current_variant.compare_at_price | money }}
            </span>
            <span class="product-price__badge">
              {{ 'products.product.on_sale' | t }}
            </span>
          {% endif %}
        </div>
      </div>

      {%- comment -%} Product Form {%- endcomment -%}
      {% form 'product', product, id: product_form_id, class: 'product-form' %}
        
        {%- comment -%} Variant Selector {%- endcomment -%}
        {% unless product.has_only_default_variant %}
          <div class="product-variants">
            {% for option in product.options_with_values %}
              <div class="product-variant-option">
                <label class="variant-label">
                  {{ option.name }}
                </label>
                <div class="variant-buttons">
                  {% for value in option.values %}
                    <input
                      type="radio"
                      id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                      name="{{ option.name }}"
                      value="{{ value | escape }}"
                      form="{{ product_form_id }}"
                      {% if option.selected_value == value %}checked{% endif %}
                      class="variant-input"
                    >
                    <label 
                      for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                      class="variant-button"
                    >
                      {{ value }}
                    </label>
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          </div>
        {% endunless %}

        {%- comment -%} Quantity Selector {%- endcomment -%}
        {% if section.settings.show_quantity_selector %}
          <div class="product-quantity">
            <label for="Quantity-{{ section.id }}" class="quantity-label">
              {{ 'products.product.quantity' | t }}
            </label>
            <quantity-selector class="quantity-selector">
              <button 
                type="button" 
                class="quantity-button quantity-minus" 
                data-action="minus"
                aria-label="{{ 'products.product.decrease_quantity' | t }}"
              >
                <svg width="12" height="2" viewBox="0 0 12 2" fill="currentColor">
                  <rect width="12" height="2"/>
                </svg>
              </button>
              <input
                type="number"
                id="Quantity-{{ section.id }}"
                name="quantity"
                value="1"
                min="1"
                class="quantity-input"
                form="{{ product_form_id }}"
                aria-label="{{ 'products.product.quantity' | t }}"
              >
              <button 
                type="button" 
                class="quantity-button quantity-plus" 
                data-action="plus"
                aria-label="{{ 'products.product.increase_quantity' | t }}"
              >
                <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor">
                  <rect x="5" width="2" height="12"/>
                  <rect y="5" width="12" height="2"/>
                </svg>
              </button>
            </quantity-selector>
          </div>
        {% endif %}

        {%- comment -%} Add to Cart Button {%- endcomment -%}
        <div class="product-form__buttons">
          <button
            type="submit"
            name="add"
            class="product-form__submit btn btn-primary"
            {% if current_variant.available == false %}disabled{% endif %}
          >
            {% if current_variant.available %}
              {{ 'products.product.add_to_cart' | t }}
            {% else %}
              {{ 'products.product.sold_out' | t }}
            {% endif %}
          </button>
        </div>

        {%- comment -%} Dynamic Checkout Buttons {%- endcomment -%}
        {% if section.settings.show_dynamic_checkout %}
          {{ form | payment_button }}
        {% endif %}

      {% endform %}

      {%- comment -%} Product Description {%- endcomment -%}
      {% if product.description != blank %}
        <div class="product-description">
          <h2 class="product-description__heading">
            {{ 'products.product.description' | t }}
          </h2>
          <div class="product-description__content">
            {{ product.description }}
          </div>
        </div>
      {% endif %}

      {%- comment -%} Share Buttons {%- endcomment -%}
      {% if section.settings.show_share_buttons %}
        <div class="product-share">
          <h3 class="product-share__heading">{{ 'products.product.share' | t }}</h3>
          <div class="product-share__buttons">
            <a 
              href="https://www.facebook.com/sharer.php?u={{ product.url | prepend: shop.url | url_encode }}"
              target="_blank"
              rel="noopener"
              class="share-button"
              aria-label="{{ 'products.product.share_facebook' | t }}"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            <a 
              href="https://twitter.com/share?url={{ product.url | prepend: shop.url | url_encode }}&text={{ product.title | url_encode }}"
              target="_blank"
              rel="noopener"
              class="share-button"
              aria-label="{{ 'products.product.share_twitter' | t }}"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
              </svg>
            </a>
            <a 
              href="https://pinterest.com/pin/create/button/?url={{ product.url | prepend: shop.url | url_encode }}&media={{ featured_image | image_url: width: 1000 | prepend: 'https:' }}&description={{ product.title | url_encode }}"
              target="_blank"
              rel="noopener"
              class="share-button"
              aria-label="{{ 'products.product.share_pinterest' | t }}"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/>
              </svg>
            </a>
          </div>
        </div>
      {% endif %}

    </div>
  </div>
</product-info>

<style>
  .section-{{ section.id }} .product-page__container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--spacing-xl) var(--spacing-md);
  }

  @media (max-width: 900px) {
    .section-{{ section.id }} .product-page__container {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }
  }
</style>

{% schema %}
{
  "name": "Product Information",
  "tag": "section",
  "class": "section-product",
  "settings": [
    {
      "type": "header",
      "content": "Product Information"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show artist/vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quantity_selector",
      "label": "Show quantity selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout buttons",
      "info": "Shows express checkout buttons (Apple Pay, Google Pay, etc.)",
      "default": true
    },
    {
      "type": "header",
      "content": "Social sharing"
    },
    {
      "type": "checkbox",
      "id": "show_share_buttons",
      "label": "Show social share buttons",
      "default": true
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Product Information"
    }
  ]
}
{% endschema %}