{% comment %}
  Image with Text Section - Shopify OS 2.0
  Versión FINAL corregida - SIN DEBUG
{% endcomment %}

{%- liquid
  assign subheading = section.settings.subheading
  assign heading = section.settings.heading
  assign text = section.settings.text
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
  assign section_image = section.settings.main_image
  assign image_position = section.settings.image_position
  assign content_alignment = section.settings.content_alignment
  assign bg_color = section.settings.background_color
-%}

<section 
  class="image-with-text image-with-text--{{ section.id }}"
  style="background-color: {{ bg_color }};"
>
  <div class="image-with-text__container">
    <div class="image-with-text__grid image-with-text__grid--{{ image_position }}">
      
      {%- comment -%} Bloque de Imagen {%- endcomment -%}
      <div class="image-with-text__media">
        {%- if section_image != blank -%}
          <img
            src="{{ section_image | image_url: width: 1500 }}"
            srcset="{{ section_image | image_url: width: 600 }} 600w,
                    {{ section_image | image_url: width: 800 }} 800w,
                    {{ section_image | image_url: width: 1000 }} 1000w,
                    {{ section_image | image_url: width: 1200 }} 1200w,
                    {{ section_image | image_url: width: 1500 }} 1500w"
            sizes="(min-width: 768px) 50vw, 100vw"
            alt="{{ section_image.alt | escape }}"
            class="image-with-text__image"
            loading="lazy"
            width="1500"
            height="1875"
          >
        {%- else -%}
          <div class="image-with-text__placeholder">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Bloque de Contenido {%- endcomment -%}
      <div class="image-with-text__content image-with-text__content--{{ content_alignment }}">
        {%- if subheading != blank -%}
          <p class="image-with-text__subheading">{{ subheading }}</p>
        {%- endif -%}

        {%- if heading != blank -%}
          <h2 class="image-with-text__heading">{{ heading }}</h2>
        {%- endif -%}

        {%- if text != blank -%}
          <div class="image-with-text__text">{{ text }}</div>
        {%- endif -%}

        {%- if button_label != blank and button_link != blank -%}
          <div class="image-with-text__button">
            <a href="{{ button_link }}" class="btn btn-secondary">
              {{ button_label }}
            </a>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

<style>
  /* Layout Base */
  .image-with-text--{{ section.id }} {
    position: relative;
    overflow: hidden;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  /* Patrón decorativo */
  .image-with-text--{{ section.id }}::after {
    content: '';
    position: absolute;
    top: 10%;
    left: -10%;
    width: 40%;
    height: 80%;
    background: radial-gradient(
      circle,
      rgba(201, 169, 97, 0.07) 0%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 1;
  }

  .image-with-text--{{ section.id }} .image-with-text__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--spacing-md, 20px);
    position: relative;
    z-index: 2;
  }

  .image-with-text--{{ section.id }} .image-with-text__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .image-with-text--{{ section.id }} .image-with-text__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 5rem;
    }
    .image-with-text--{{ section.id }} .image-with-text__grid--right .image-with-text__media { 
      order: 2; 
    }
    .image-with-text--{{ section.id }} .image-with-text__grid--right .image-with-text__content { 
      order: 1; 
    }
  }

  /* Estilos de Imagen - VERSIÓN FINAL CORREGIDA */
  .image-with-text--{{ section.id }} .image-with-text__media {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 4px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    background-color: #f5f5f5;
  }

  .image-with-text--{{ section.id }} .image-with-text__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 1s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .image-with-text--{{ section.id }} .image-with-text__media:hover .image-with-text__image {
    transform: scale(1.05);
  }

  .image-with-text--{{ section.id }} .image-with-text__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f0f0f0;
  }

  .image-with-text--{{ section.id }} .placeholder-svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  /* Tipografía y Textos */
  .image-with-text--{{ section.id }} .image-with-text__subheading {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #C9A961;
    margin-bottom: 1rem;
  }

  .image-with-text--{{ section.id }} .image-with-text__heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.2;
    margin-bottom: 1.5rem;
    color: #2C2C2C;
  }

  .image-with-text--{{ section.id }} .image-with-text__text {
    font-size: 1.1rem;
    line-height: 1.7;
    color: #4A4A4A;
    margin-bottom: 2rem;
  }

  .image-with-text--{{ section.id }} .image-with-text__content--center {
    text-align: center;
  }

  @media (max-width: 767px) {
    .image-with-text--{{ section.id }} {
      padding: {{ section.settings.padding_top | divided_by: 1.5 }}px 20px {{ section.settings.padding_bottom | divided_by: 1.5 }}px;
    }
    
    .image-with-text--{{ section.id }} .image-with-text__media {
      aspect-ratio: 3 / 4;
    }
  }
</style>

{% schema %}
{
  "name": "Image with Text",
  "tag": "section",
  "class": "section-image-with-text",
  "settings": [
    {
      "type": "header",
      "content": "Imagen"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Imagen"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Posición de la imagen",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "right", "label": "Derecha" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Nuestra Galería"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>Comparte la historia detrás de tus obras de arte.</p>"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Alineación",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Botón (opcional)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Etiqueta botón"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace botón"
    },
    {
      "type": "header",
      "content": "Colores y espaciado"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fondo",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Superior",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Inferior",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Image with Text"
    }
  ]
}
{% endschema %}