{% comment %}
  Featured Collection Section - Shopify 2.0 Standards Compliant
  Fully configurable through Theme Editor
{% endcomment %}

{%- liquid
  assign collection = section.settings.collection
  assign products_to_show = section.settings.products_to_show
  assign columns_desktop = section.settings.columns_desktop
  assign columns_mobile = section.settings.columns_mobile
-%}

<section 
  class="collection-grid section-{{ section.id }}"
  style="
    --grid-columns-desktop: {{ columns_desktop }};
    --grid-columns-mobile: {{ columns_mobile }};
  "
>
  {% if section.settings.title != blank %}
    <h2 class="section-title">
      {{ section.settings.title }}
    </h2>
  {% endif %}
  
  {% if collection != blank %}
    <div class="product-grid">
      {% for product in collection.products limit: products_to_show %}
        <article class="product-card">
          <a href="{{ product.url }}" aria-label="{{ product.title | escape }}">
            <div class="product-image-wrapper">
              {% if product.featured_image %}
                {{- product.featured_image | image_url: width: 800 | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 1200px) calc(100vw / 3 - 4rem), (min-width: 768px) calc(100vw / 2 - 3rem), 100vw',
                  widths: '300, 400, 500, 600, 800',
                  class: 'product-image',
                  alt: product.featured_image.alt | default: product.title
                -}}
              {% else %}
                <div class="product-image-placeholder">
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {% endif %}
              
              {% if product.compare_at_price > product.price %}
                <span class="product-badge">
                  {{ 'products.product.on_sale' | t }}
                </span>
              {% endif %}
            </div>
            
            <div class="product-info">
              <h3 class="product-title">{{ product.title }}</h3>
              
              {% if product.vendor != blank and section.settings.show_vendor %}
                <p class="product-artist">{{ product.vendor }}</p>
              {% endif %}
              
              <p class="product-price">
                {% if product.compare_at_price > product.price %}
                  <span class="product-price--compare">
                    {{ product.compare_at_price | money }}
                  </span>
                {% endif %}
                <span class="product-price--regular">
                  {{ product.price | money }}
                </span>
              </p>
            </div>
          </a>
        </article>
      {% endfor %}
    </div>
    
    {% if section.settings.show_view_all and collection.products_count > products_to_show %}
      <div class="collection-grid__footer">
        <a href="{{ collection.url }}" class="btn btn-primary">
          {{ 'collections.view_all' | t }}
        </a>
      </div>
    {% endif %}
  {% else %}
    <div class="collection-grid__empty">
      <p>{{ 'collections.no_products' | t }}</p>
    </div>
  {% endif %}
</section>

<style>
  .section-{{ section.id }} .product-grid {
    grid-template-columns: repeat(var(--grid-columns-mobile), 1fr);
  }

  @media (min-width: 768px) {
    .section-{{ section.id }} .product-grid {
      grid-template-columns: repeat(var(--grid-columns-desktop), 1fr);
    }
  }

  .section-{{ section.id }} .product-price--compare {
    text-decoration: line-through;
    color: var(--color-gray);
    font-size: 0.9em;
    margin-right: 0.5rem;
  }

  .section-{{ section.id }} .product-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-light-gray);
  }

  .section-{{ section.id }} .placeholder-svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .section-{{ section.id }} .collection-grid__footer {
    text-align: center;
    margin-top: var(--spacing-lg);
  }

  .section-{{ section.id }} .collection-grid__empty {
    text-align: center;
    color: var(--color-gray);
    padding: var(--spacing-xl) 0;
    font-size: 1.1rem;
  }
</style>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "class": "section-collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Featured Works"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Maximum products to show",
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show artist/vendor name",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' button",
      "default": true
    },
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Number of columns on desktop",
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Number of columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1 column"
        },
        {
          "value": "2",
          "label": "2 columns"
        }
      ],
      "default": "1"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection",
      "settings": {
        "title": "Featured Works",
        "products_to_show": 6
      }
    }
  ]
}
{% endschema %}