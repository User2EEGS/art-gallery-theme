{% comment %}
  Testimonials Section - Shopify 2.0
  Customer reviews and testimonials
{% endcomment %}

<div 
  class="testimonials-section section-{{ section.id }}"
  style="
    --testimonials-bg: {{ section.settings.background_color }};
    --testimonials-text: {{ section.settings.text_color }};
  "
>
  <div class="testimonials-section__container">
    
    {% if section.settings.heading != blank %}
      <h2 class="testimonials-section__heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="testimonials-section__subheading">
        {{ section.settings.subheading }}
      </p>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="testimonials-grid">
        {% for block in section.blocks %}
          <div class="testimonial-card testimonial-animate" {{ block.shopify_attributes }}>
            
            {%- comment -%} Stars Rating {%- endcomment -%}
            {% if block.settings.rating > 0 %}
              <div class="testimonial-rating">
                {% for i in (1..5) %}
                  <svg class="star {% if i <= block.settings.rating %}star--filled{% endif %}" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                {% endfor %}
              </div>
            {% endif %}

            {%- comment -%} Quote {%- endcomment -%}
            {% if block.settings.quote != blank %}
              <blockquote class="testimonial-quote">
                <p>{{ block.settings.quote }}</p>
              </blockquote>
            {% endif %}

            {%- comment -%} Author Info {%- endcomment -%}
            <div class="testimonial-author">
              {% if block.settings.author_image != blank %}
                <div class="testimonial-author__image">
                  {{- block.settings.author_image | image_url: width: 80 | image_tag:
                    loading: 'lazy',
                    sizes: '80px',
                    widths: '80',
                    alt: block.settings.author_name | escape
                  -}}
                </div>
              {% endif %}

              <div class="testimonial-author__info">
                {% if block.settings.author_name != blank %}
                  <p class="testimonial-author__name">{{ block.settings.author_name }}</p>
                {% endif %}
                
                {% if block.settings.author_title != blank %}
                  <p class="testimonial-author__title">{{ block.settings.author_title }}</p>
                {% endif %}
              </div>
            </div>

          </div>
        {% endfor %}
      </div>
    {% endif %}

  </div>
</div>

<style>
  .section-{{ section.id }} {
    background-color: var(--testimonials-bg);
    color: var(--testimonials-text);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    position: relative;
    overflow: hidden;
  }

  .section-{{ section.id }} .testimonials-section__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }

  .section-{{ section.id }} .testimonials-section__heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 400;
    text-align: center;
    margin-bottom: var(--spacing-sm);
    color: var(--testimonials-text);
  }

  .section-{{ section.id }} .testimonials-section__subheading {
    text-align: center;
    font-size: 1.1rem;
    color: var(--testimonials-text);
    opacity: 0.8;
    margin-bottom: var(--spacing-xl);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-{{ section.id }} .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-lg);
    margin-top: var(--spacing-xl);
  }

  .section-{{ section.id }} .testimonial-card {
    background-color: var(--color-white);
    padding: var(--spacing-lg);
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .section-{{ section.id }} .testimonial-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  /* Rating Stars */
  .section-{{ section.id }} .testimonial-rating {
    display: flex;
    gap: 0.25rem;
  }

  .section-{{ section.id }} .star {
    color: #E8E8E8;
    transition: color 0.3s ease;
  }

  .section-{{ section.id }} .star--filled {
    color: var(--color-gold);
  }

  /* Quote */
  .section-{{ section.id }} .testimonial-quote {
    flex: 1;
    margin: 0;
    position: relative;
  }

  .section-{{ section.id }} .testimonial-quote::before {
    content: '"';
    font-family: 'Cormorant Garamond', serif;
    font-size: 4rem;
    line-height: 1;
    color: var(--color-gold);
    opacity: 0.2;
    position: absolute;
    top: -0.5rem;
    left: -0.5rem;
  }

  .section-{{ section.id }} .testimonial-quote p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-charcoal);
    margin: 0;
    font-style: italic;
  }

  /* Author */
  .section-{{ section.id }} .testimonial-author {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--color-light-gray);
  }

  .section-{{ section.id }} .testimonial-author__image {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .section-{{ section.id }} .testimonial-author__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .section-{{ section.id }} .testimonial-author__name {
    font-weight: 600;
    color: var(--color-charcoal);
    margin: 0 0 0.25rem 0;
    font-size: 1rem;
  }

  .section-{{ section.id }} .testimonial-author__title {
    font-size: 0.9rem;
    color: var(--color-gray);
    margin: 0;
  }

  /* Animations */
  .testimonial-animate {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .testimonial-animate.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .section-{{ section.id }} .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  (function() {
    const section = document.querySelector('.section-{{ section.id }}');
    if (!section) return;

    const testimonials = section.querySelectorAll('.testimonial-animate');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add('animate-in');
          }, index * 150);
        }
      });
    }, { threshold: 0.1 });

    testimonials.forEach(testimonial => observer.observe(testimonial));
  })();
</script>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
