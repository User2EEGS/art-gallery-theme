<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% comment %}
      Font preloading:
      1. Preconnect to font CDN for faster connection
      2. Preload only the critical font variant (base weight)
      3. Additional variants load on-demand via @font-face
    {% endcomment %}
    {% comment %} Font preloading removed - using Google Fonts via CSS {% endcomment %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Estilos personalizados de galería %}
    {{ 'gallery-styles.css' | asset_url | stylesheet_tag }}
    {{ 'dropdown-premium-styles.css' | asset_url | stylesheet_tag }}


    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}

    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </head>

  <body>
    {% sections 'header-group' %}

    {{ content_for_layout }}

    {% sections 'footer-group' %}

    {% # JavaScript de animaciones %}
    <script src="{{ 'scroll-animations.js' | asset_url }}" defer></script>
    
  </body>
</html>